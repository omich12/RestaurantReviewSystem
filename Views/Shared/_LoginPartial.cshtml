@using Microsoft.AspNetCore.Identity
@using RestaurantReviewSystem.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav d-flex align-items-center">

    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item me-3">
            <span class="navbar-text text-white">
                👋 Hello, <strong>@(User.IsInRole("Admin") ? "Admin" : "User")</strong>
            </span>
        </li>
        <li class="nav-item">
            <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-secondary btn-sm">
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item me-2">
            <a class="btn btn-outline-primary btn-sm" asp-controller="Account" asp-action="Register">
                Register
            </a>
        </li>
        <li class="nav-item">
            <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">
                Login
            </a>
        </li>
    }

</ul>
